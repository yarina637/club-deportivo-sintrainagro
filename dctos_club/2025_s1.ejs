                        </li>

                        <li
                            class="list-group-item list-group-item-success d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">3. Reinaldo Ruiz (Delicias)</span>
                            <span class="badge bg-secondary rounded-pill">9 Goles</span>
                        </li>

                    </ul>

