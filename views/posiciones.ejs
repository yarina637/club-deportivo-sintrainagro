<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tabla de Posiciones | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-oswald { font-family: 'Oswald', sans-serif; }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900" x-data="{ categoria: 'masculino' }">

<header style="background-color: #064e3b;" class="text-white shadow-2xl border-b-4 border-yellow-500 sticky top-0 z-50">
    <div class="container mx-auto px-6 py-4">
        <div class="flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="bg-white p-2 rounded-2xl shadow-2xl transform -rotate-2">
                    <img src="/img/logoclub.png" alt="Logo Club" class="h-20 w-auto object-contain">
                </div>
                <div class="hidden sm:block">
                    <h1 class="font-oswald text-3xl font-black uppercase italic leading-none tracking-tighter">
                        Club <span class="text-yellow-400">Deportivo</span>
                    </h1>
                </div>
            </div>
            <nav class="flex items-center gap-2">
                <a href="/publico" class="bg-yellow-500 hover:bg-yellow-400 text-green-900 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">Inicio</a>
                <button onclick="window.history.back()" class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border border-white/20">Volver</button>
            </nav>
        </div>
    </div>
</header>

<main class="container mx-auto px-4 py-12">
    <header class="text-center mb-8">
        <h2 class="font-oswald text-5xl uppercase italic font-black text-[#064e3b]">
            Tabla de <span :class="categoria === 'masculino' ? 'text-yellow-500' : 'text-pink-600'">Posiciones</span>
        </h2>
        <p class="text-slate-400 uppercase tracking-[0.3em] font-bold text-[10px] mt-2 italic">Temporada Oficial 2026</p>
    </header>

    <div class="flex justify-center mb-12">
        <div class="inline-flex bg-slate-200 p-1 rounded-2xl shadow-inner">
            <button @click="categoria = 'masculino'" 
                :class="categoria === 'masculino' ? 'bg-[#064e3b] text-white shadow-lg' : 'text-slate-500'"
                class="px-8 py-3 rounded-xl font-black uppercase text-xs transition-all duration-300">
                ⚽ Masculino
            </button>
            <button @click="categoria = 'femenino'" 
                :class="categoria === 'femenino' ? 'bg-pink-600 text-white shadow-lg' : 'text-slate-500'"
                class="px-8 py-3 rounded-xl font-black uppercase text-xs transition-all duration-300">
                ♀️ Femenino
            </button>
        </div>
    </div>

    <div class="max-w-5xl mx-auto bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-200">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr :class="categoria === 'masculino' ? 'bg-[#064e3b]' : 'bg-pink-700'" class="text-white font-oswald uppercase text-[12px] tracking-widest transition-colors duration-500">
                        <th class="p-6 text-center w-20">#</th>
                        <th class="p-6">Equipo / Finca</th>
                        <th class="p-6 text-center">PJ</th>
                        <th class="p-6 text-center">PG</th>
                        <th class="p-6 text-center">PE</th>
                        <th class="p-6 text-center">PP</th>
                        <th class="p-6 text-center">GF</th>
                        <th class="p-6 text-center">GC</th>
                        <th class="p-6 text-center bg-black/20 text-white font-black text-sm italic">PTS</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% equipos.forEach((eq, index) => { %>
                    <tr x-show="categoria === '<%= eq.categoria ? eq.categoria.toLowerCase() : 'masculino' %>'" 
                        class="hover:bg-slate-50 transition-colors group">
                        
                        <td class="p-6 text-center">
                            <span :class="categoria === 'masculino' ? 'bg-yellow-500 text-green-900' : 'bg-pink-500 text-white'" 
                                  class="inline-flex items-center justify-center w-10 h-10 rounded-full font-oswald font-bold text-lg shadow-md">
                                <%= index + 1 %>
                            </span>
                        </td>

                        <td class="p-6">
                            <span class="font-black text-slate-800 uppercase italic tracking-tight text-base group-hover:translate-x-2 transition-transform inline-block">
                                <%= eq.equipo %>
                            </span>
                        </td>

                        <td class="p-6 text-center font-bold text-slate-600"><%= eq.pj %></td>
                        <td class="p-6 text-center text-slate-500 font-bold"><%= eq.pg %></td>
                        <td class="p-6 text-center text-slate-500"><%= eq.pe %></td>
                        <td class="p-6 text-center text-red-400"><%= eq.pp %></td>
                        <td class="p-6 text-center text-slate-500"><%= eq.gf %></td>
                        <td class="p-6 text-center text-slate-400"><%= eq.gc %></td>

                        <td class="p-6 text-center bg-slate-50">
                            <span :class="categoria === 'masculino' ? 'text-[#064e3b]' : 'text-pink-600'" 
                                  class="text-2xl font-oswald font-black transition-colors">
                                <%= eq.puntos %>
                            </span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <div :class="categoria === 'masculino' ? 'border-yellow-500' : 'border-pink-500'" 
             class="bg-slate-900 p-5 flex flex-wrap gap-6 justify-center text-[10px] uppercase font-black text-slate-400 tracking-widest border-t-4 transition-colors">
            <div class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-500 rounded-full"></span> <span>PJ: Jugados</span></div>
            <div class="flex items-center gap-2"><span class="w-2 h-2 bg-green-500 rounded-full"></span> <span>PG: Ganados</span></div>
            <div class="flex items-center gap-2"><span class="w-2 h-2 bg-white/20 rounded-full"></span> <span>DG: Dif. Goles</span></div>
            <div class="ml-auto italic" :class="categoria === 'masculino' ? 'text-yellow-500' : 'text-pink-400'">Clasifican los mejores 4</div>
        </div>
    </div>
</main>

<footer class="bg-[#052e21] text-white pt-16 pb-8 mt-20 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
            
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 mb-2 tracking-widest text-lg font-bold">Club Deportivo</h4>
                <p class="text-green-100/40 text-[11px] leading-relaxed">
                    Portal oficial de noticias y resultados.<br>
                    Sintrainagro 2026.
                </p>
            </div>

            <div class="flex flex-col items-center justify-center">
                <div class="bg-white/5 p-6 rounded-3xl border border-white/10 backdrop-blur-sm flex justify-center gap-8 w-full">
                    <a href="https://www.comfama.com" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfama.png" alt="Comfama" class="h-10 w-auto">
                    </a>
                    <a href="https://www.comfenalcoantioquia.com.co" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfenalco.png" alt="Comfenalco" class="h-10 w-auto">
                    </a>
                </div>
                </div>

            <div class="text-center md:text-right">
                <p class="text-2xl font-black uppercase tracking-widest text-white italic leading-none">Sintrainagro</p>
                <div class="h-1 w-12 bg-yellow-500 ml-auto my-3 hidden md:block"></div>
                <p class="text-green-500 text-[10px] uppercase font-bold tracking-wider">
                    © 2026 Urabá: <span class="text-white">Tierra de campeones</span>
                </p>
            </div>

        </div>

        <div class="mt-12 pt-8 border-t border-white/5 text-center">
            <p class="text-[9px] text-white/20 uppercase tracking-[0.5em]">Desarrollo Técnico - Comité Deportivo</p>
        </div>
    </div>
</footer>
</body>
</html>