<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Noticia | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-10">
    <div class="max-w-lg mx-auto bg-white p-8 rounded shadow-xl border-t-4 border-blue-600">
        <h1 class="text-2xl font-bold mb-6 text-blue-900">📝 Editar Publicación</h1>
        
        <!-- IMPORTANTE: Añadimos enctype para que la imagen viaje al servidor -->
        <form action="/actualizar/<%= noticia.id %>" method="POST" enctype="multipart/form-data" class="space-y-4">
            
            <div>
                <label class="block font-bold text-gray-700 mb-1">Título</label>
                <input type="text" name="titulo" value="<%= noticia.titulo %>" required 
                       class="w-full border-2 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none border-slate-200">
            </div>

            <!-- VISTA PREVIA DE LA IMAGEN ACTUAL -->
            <div>
                <label class="block font-bold text-gray-700 mb-1">Imagen Actual</label>
                <% if (noticia.imagen_url) { %>
                    <img src="<%= noticia.imagen_url %>" alt="Actual" class="w-32 h-20 object-cover rounded mb-2 border">
                <% } else { %>
                    <p class="text-xs text-gray-400 mb-2 italic">No hay imagen previa</p>
                <% } %>
                
                <input type="file" name="imagen" accept="image/*" 
                       class="w-full p-2 border-2 border-dashed border-slate-300 rounded-lg hover:bg-slate-50 transition-colors text-sm">
                <p class="text-[10px] text-gray-500 mt-1 uppercase italic">Selecciona un archivo solo si quieres cambiar la foto actual</p>
            </div>

            <div>
                <label class="block font-bold text-gray-700 mb-1">Contenido</label>
                <textarea name="contenido" required 
                          class="w-full border-2 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none border-slate-200" 
                          rows="5"><%= noticia.contenido %></textarea>
            </div>

            <div class="flex gap-2 pt-4">
                <button type="submit" class="flex-1 bg-blue-600 text-white px-6 py-3 rounded font-bold hover:bg-blue-700 transition uppercase text-sm tracking-wider">
                    Guardar Cambios
                </button>
                <a href="/" class="bg-gray-400 text-white px-6 py-3 rounded font-bold hover:bg-gray-500 transition uppercase text-sm tracking-wider">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</body>
</html>