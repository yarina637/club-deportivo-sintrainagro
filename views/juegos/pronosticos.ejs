<%- include('../layouts/header.ejs') %>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quinielas de Pronósticos - Sintrainagro</title> 
    <!-- Enlace a Bootstrap CSS se asume en header.ejs -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f7f9; /* Fondo de la página */
        }
        /* Estilos básicos de los inputs de puntaje */
        .score-input {
            width: 55px;
            text-align: center;
        }
        /* Estilos de alerta (para la función displayStatus) */
        .alert-success { background-color: #d4edda; color: #155724; border-color: #c3e6cb; }
        .alert-danger { background-color: #f8d7da; color: #721c24; border-color: #f5c6cb; }
        .alert-warning { background-color: #fff3cd; color: #856404; border-color: #ffeeba; }
        .alert-info { background-color: #d1ecf1; color: #0c5460; border-color: #bee5eb; }
        
        /* Estilo para la tarjeta de Pronósticos (simula el borde del diseño anterior) */
        .card-pronosticos {
            border-top: 4px solid #0d6efd; 
            border-radius: 0.5rem;
        }
        /* Estilo para simular el hover de las filas de pronóstico */
        .hover-shadow:hover {
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
            transition: box-shadow 0.3s;
        }
    </style>
</head>
<body>
    
    <main class="container py-4"> 
        
        <div class="row">
            
            <div class="col-lg-8 mb-4">
                
                <div class="card shadow-lg card-pronosticos">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0 font-weight-bold"><i class="fas fa-edit me-2"></i> Próxima Jornada: Jornada 5</h4>
                    </div>
                    
                    <div class="card-body">
                           <div id="status-message-container" class="mt-0 mb-4">
                            </div>
                        <form id="formPronosticos" class="space-y-4">
                            
                            <!-- Partido 1 -->
                            <div class="d-flex align-items-center justify-content-between p-3 border rounded mb-3 bg-light hover-shadow">
                                <span class="font-weight-bold w-25 text-start">Atléticas</span>
                                <div class="d-flex align-items-center">
                                    <input type="number" min="0" max="99" class="form-control score-input me-3" placeholder="0" required name="score_1_local" id="score_1_local">
                                    <span class="font-weight-bold">-</span>
                                    <input type="number" min="0" max="99" class="form-control score-input ms-3" placeholder="0" required name="score_1_visitante" id="score_1_visitante">
                                </div>
                                <span class="font-weight-bold w-25 text-end">Poderosas</span>
                            </div>

                            <!-- Partido 2 -->
                            <div class="d-flex align-items-center justify-content-between p-3 border rounded mb-3 bg-white hover-shadow">
                                <span class="font-weight-bold w-25 text-start">Las Potras</span>
                                <div class="d-flex align-items-center">
                                    <input type="number" min="0" max="99" class="form-control score-input me-3" placeholder="0" required name="score_2_local" id="score_2_local">
                                    <span class="font-weight-bold">-</span>
                                    <input type="number" min="0" max="99" class="form-control score-input ms-3" placeholder="0" required name="score_2_visitante" id="score_2_visitante">
                                </div>
                                <span class="font-weight-bold w-25 text-end">Amazonas</span>
                            </div>

                            <!-- Partido 3 -->
                            <div class="d-flex align-items-center justify-content-between p-3 border rounded mb-3 bg-light hover-shadow">
                                <span class="font-weight-bold w-25 text-start">Club Deportivo</span>
                                <div class="d-flex align-items-center">
                                    <input type="number" min="0" max="99" class="form-control score-input me-3" placeholder="0" required name="score_3_local" id="score_3_local">
                                    <span class="font-weight-bold">-</span>
                                    <input type="number" min="0" max="99" class="form-control score-input ms-3" placeholder="0" required name="score_3_visitante" id="score_3_visitante">
                                </div>
                                <span class="font-weight-bold w-25 text-end">Los Leones</span>
                            </div>
                            
                            <div class="alert alert-warning small mt-4 p-3 rounded shadow-sm text-sm" role="alert">
                                <i class="fas fa-exclamation-triangle me-1"></i> **Límite:** Puedes enviar tus pronósticos hasta 15 minutos antes del primer partido. ¡Sé puntual!
                            </div>
                        
                    </div>
                    
                    <div class="card-footer text-center">
                        <button type="submit" id="saveButton" class="btn btn-success btn-lg rounded-pill shadow-sm transition-hover">
                            <i class="fas fa-paper-plane me-2"></i> Guardar Mis Pronósticos
                        </button>
                    </div>
                    </form> </div>

            </div>

            <!-- Ranking Global -->
            <div class="col-lg-4">
                
                <div class="card shadow-lg">
                    <div class="card-header bg-dark text-white">
                        <h4 class="mb-0 font-weight-bold"><i class="fas fa-list-ol me-2"></i> Ranking Global de Expertos</h4>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="text-center">#</th>
                                        <th scope="col" class="text-start">Participante</th>
                                        <th scope="col" class="text-end">Puntos</th>
                                    </tr>
                                </thead>
                                <tbody id="ranking-body">
                                    <tr><td colspan="3" class="text-center text-muted py-4">Cargando ranking...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer text-center small">
                        <span class="text-secondary">Tu ID: <span id="user-id-display" class="font-weight-bold text-dark">...</span></span>
                    </div>
                </div>

                <div class="alert alert-info mt-4 p-3 rounded shadow-sm text-center small">
                    <i class="fas fa-trophy me-1"></i> **Reglas Clave:** Acierto de resultado (3 pts), Acierto de ganador (1 pt). ¡El 1er lugar al final de la temporada gana una camiseta oficial!
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5 mb-3">
            <a href="#" class="btn btn-secondary py-2 px-4 rounded-pill d-inline-flex align-items-center">
                <i class="fas fa-arrow-left me-2"></i> Volver a la Página Principal
            </a>
        </div>

    </main>

    <!-- Cargamos el bundle de Bootstrap 5 JS para funcionalidad de alerts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script type="module">
        // Importaciones de Firebase
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, onSnapshot, collection, query, limit } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        import { setLogLevel } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Establecer nivel de log (Opcional, útil para depuración)
        setLogLevel('debug');
        
        // ===========================================
        // 1. INICIALIZACIÓN Y AUTENTICACIÓN DE FIREBASE
        // ===========================================

        const JORNADA_ID = 'jornada_5'; 

        // Variables Globales Inyectadas
        const initialAuthToken = typeof __initial_auth_token !== 'undefined' ? __initial_auth_token : 'DUMMY_TOKEN_FOR_SANDBOX';
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

        let firebaseConfig = null;

        try {
            // Intentar usar la configuración real inyectada por el entorno.
            if (typeof __firebase_config !== 'undefined' && __firebase_config.length > 2) {
                firebaseConfig = JSON.parse(__firebase_config);
            } else {
                // FALLBACK: Configuración dummy
                firebaseConfig = {
                    apiKey: "dummy-key",
                    authDomain: "dummy-project.firebaseapp.com",
                    projectId: "dummy-project",
                    storageBucket: "dummy-project.appspot.com",
                    messagingSenderId: "123456789012",
                    appId: "1:123456789012:web:1234567890abcdef"
                };
                console.warn("⚠️ Usando configuración de Firebase DUMMY. La persistencia de datos funcionará en el Sandbox, pero no en una base de datos real sin la configuración inyectada.");
            }
        } catch (e) {
            console.error("Error al parsear la configuración de Firebase. Se usará la configuración DUMMY.", e);
            firebaseConfig = { apiKey: "dummy-key", projectId: "dummy-project", appId: "1:123456789012:web:1234567890abcdef" };
        }

        let db, auth, userId = null;

        // Inicializar si la configuración (real o dummy) fue exitosa
        const app = initializeApp(firebaseConfig);
        auth = getAuth(app);
        db = getFirestore(app);

        // Intentar autenticación
        onAuthStateChanged(auth, async (user) => {
            if (user) {
                userId = user.uid;
                document.getElementById('user-id-display').textContent = userId;
                console.log('✅ Usuario autenticado:', userId);
                
                // Una vez autenticado, cargar los datos y sembrar el ranking
                await seedRanking(); // Asegurar datos de ranking antes de cargarlos
                loadUserPronosticos();
                loadRanking();

            } else {
                // Si no hay usuario, intentar firmar de forma personalizada o anónima
                try {
                    if (initialAuthToken && initialAuthToken !== 'DUMMY_TOKEN_FOR_SANDBOX') {
                        await signInWithCustomToken(auth, initialAuthToken);
                    } else {
                        await signInAnonymously(auth);
                    }
                } catch (error) {
                    console.error("Error durante la autenticación:", error);
                    displayStatus('error', 'Error de autenticación. No se pudo iniciar sesión en la base de datos.');
                }
            }
        });


        // ===========================================
        // 2. LÓGICA DE CÁLCULO DE PUNTOS
        // ===========================================

        /**
         * Compara los pronósticos con los resultados reales y calcula el puntaje.
         * @param {object} pronosticos - e.g., {score_1_local: '3', score_1_visitante: '1', ...}
         * @returns {number} Puntuación total obtenida.
         */
        function calcularPuntos(pronosticos) {
            let puntosTotales = 0;

            // SIMULACIÓN DE RESULTADOS REALES DE LA JORNADA (Usados para calcular puntos inmediatamente)
            const resultadosReales = {
                'partido_1': { local: 2, visitante: 1 }, 
                'partido_2': { local: 0, visitante: 0 }, 
                'partido_3': { local: 3, visitante: 2 } 
            };

            const partidos = [
                { id: 'partido_1', local: 'score_1_local', visitante: 'score_1_visitante' },
                { id: 'partido_2', local: 'score_2_local', visitante: 'score_2_visitante' },
                { id: 'partido_3', local: 'score_3_local', visitante: 'score_3_visitante' },
            ];

            partidos.forEach(partido => {
                const pronosticoLocal = parseInt(pronosticos[partido.local]);
                const pronosticoVisitante = parseInt(pronosticos[partido.visitante]);
                const realLocal = resultadosReales[partido.id].local;
                const realVisitante = resultadosReales[partido.id].visitante;

                if (isNaN(pronosticoLocal) || isNaN(pronosticoVisitante)) {
                    return;
                }

                // 1. RESULTADO EXACTO (3 PUNTOS)
                if (pronosticoLocal === realLocal && pronosticoVisitante === realVisitante) {
                    puntosTotales += 3;
                    return; 
                }

                // 2. GANADOR/EMPATADOR CORRECTO (1 PUNTO)
                const resultadoReal = Math.sign(realLocal - realVisitante);
                const resultadoPronosticado = Math.sign(pronosticoLocal - pronosticoVisitante);

                if (resultadoPronosticado === resultadoReal) {
                    puntosTotales += 1;
                }
            });

            return puntosTotales;
        }

        // ===========================================
        // 3. FUNCIONES DE FIREBASE (GUARDAR Y CARGAR)
        // ===========================================
        
        /**
         * Guarda los pronósticos del usuario para la jornada actual (Ruta privada).
         * @param {object} data - Datos del formulario.
         * @param {number} points - Puntos calculados (simulados).
         */
        async function savePronosticos(data, points) {
            if (!userId || !db) {
                console.error("No se puede guardar: Usuario no autenticado o DB no inicializada.");
                return displayStatus('error', 'Error: No se puede guardar. Por favor, recarga e inténtalo de nuevo.');
            }

            // Ruta de datos privados: /artifacts/{appId}/users/{userId}/pronosticos_jornada/{jornadaId}
            const docRef = doc(db, 'artifacts', appId, 'users', userId, 'pronosticos_jornada', JORNADA_ID);

            const pronosticoData = {
                userId: userId,
                jornadaId: JORNADA_ID,
                pronosticos: data,
                puntos_calculados: points,
                timestamp: Date.now()
            };

            try {
                await setDoc(docRef, pronosticoData);
                console.log("✅ Pronósticos guardados en Firestore.");
                displayStatus('success', `¡Tus pronósticos han sido guardados! Puntos simulados: ${points}.`);
                
                // NOTA: En una app real, actualizarías el ranking aquí, pero para la simulación
                // solo actualizamos la simulación de puntos del ranking.
                await updateRankingScore(points);

            } catch (e) {
                console.error("Error al guardar en Firestore: ", e);
                displayStatus('error', 'Error al guardar. Por favor, verifica tu conexión e inténtalo de nuevo.');
            }
        }

        /**
         * Carga los pronósticos previos del usuario y llena el formulario (Real-time).
         */
        function loadUserPronosticos() {
            if (!userId || !db) return;

            // Ruta de datos privados
            const docRef = doc(db, 'artifacts', appId, 'users', userId, 'pronosticos_jornada', JORNADA_ID);
            
            // Usamos onSnapshot para mantener el formulario actualizado 
            onSnapshot(docRef, (docSnap) => {
                if (docSnap.exists()) {
                    const data = docSnap.data().pronosticos;
                    console.log("📝 Pronósticos previos encontrados:", data);
                    
                    // Llenar el formulario con los datos guardados
                    for (const key in data) {
                        const input = document.getElementById(key);
                        // Convertir a cadena si es un número, ya que input.value espera una cadena
                        if (input) {
                            input.value = String(data[key]);
                        }
                    }
                    displayStatus('info', 'Se cargaron tus pronósticos guardados previamente.');

                } else {
                    console.log("🤷‍♂️ No se encontraron pronósticos previos para esta jornada.");
                }
            }, (error) => {
                console.error("Error al cargar pronósticos previos: ", error);
            });
        }
        
        /**
         * Carga el ranking de forma simulada y lo actualiza en tiempo real (Ruta pública).
         */
        function loadRanking() {
            if (!db) return;

            // Ruta de datos públicos: /artifacts/{appId}/public/data/ranking
            const rankingRef = collection(db, 'artifacts', appId, 'public', 'data', 'ranking');
            
            // Usar query sin orderBy para evitar errores de índice y ordenar en el cliente
            const q = query(rankingRef, limit(15)); 

            onSnapshot(q, (snapshot) => {
                let rankingData = [];
                snapshot.forEach((doc) => {
                    rankingData.push(doc.data());
                });

                // Ordenar en el cliente (Descendente por puntos_totales)
                rankingData.sort((a, b) => (b.puntos_totales || 0) - (a.puntos_totales || 0));

                renderRanking(rankingData);
            }, (error) => {
                console.error("Error al cargar el ranking: ", error);
                document.getElementById('ranking-body').innerHTML = '<tr><td colspan="3" class="text-center text-danger py-4">Error al cargar el ranking.</td></tr>';
            });
        }
        
        /**
         * Renderiza la tabla de ranking.
         * @param {Array<Object>} ranking - Array de objetos de ranking.
         */
        function renderRanking(ranking) {
            const tbody = document.getElementById('ranking-body');
            tbody.innerHTML = ''; // Limpiar

            if (ranking.length === 0) {
                 tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-4">Aún no hay participantes en el ranking.</td></tr>';
                 return;
            }

            ranking.forEach((user, index) => {
                const isCurrentUser = user.userId === userId; 
                const rowClass = isCurrentUser ? 'table-success border-start border-success border-4' : '';
                const nameClass = isCurrentUser ? 'font-weight-bold text-success' : 'text-dark';
                
                const row = `
                    <tr class="${rowClass}">
                        <td class="text-center small">${index + 1}</td>
                        <td class="${nameClass} small">
                            ${isCurrentUser ? '🏆 ' : ''}${user.nombre} ${isCurrentUser ? '(Tú)' : ''}
                        </td>
                        <td class="text-end font-weight-bold small text-secondary">${user.puntos_totales || 0}</td>
                    </tr>
                `;
                tbody.innerHTML += row;
            });
        }

        // ===========================================
        // 4. MANEJO DE EVENTOS DEL FORMULARIO
        // ===========================================

        document.getElementById('formPronosticos').addEventListener('submit', async function (e) {
            e.preventDefault();
            
            if (!userId || !db) {
                return displayStatus('error', 'Error: La aplicación no está lista para guardar. Verifica la conexión a Firebase.');
            }

            const button = document.getElementById('saveButton');
            button.disabled = true;
            button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Guardando...';

            // Recoger datos del formulario
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            // Convertir a número antes de calcular/guardar
            for (const key in data) {
                data[key] = parseInt(data[key]);
            }
            
            // Calcular puntos de simulación
            const puntosObtenidos = calcularPuntos(data);

            // Guardar en Firestore
            await savePronosticos(data, puntosObtenidos);

            // Restablecer botón
            button.disabled = false;
            button.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Guardar Mis Pronósticos';
        });

        // ===========================================
        // 5. UTILIDADES
        // ===========================================

        /**
         * Muestra el mensaje de estado en la interfaz de usuario.
         * @param {string} type - 'success', 'error', 'warning', 'info'.
         * @param {string} message - El mensaje a mostrar.
         */
        function displayStatus(type, message) {
            const container = document.getElementById('status-message-container');
            const icon = type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-times-circle' : 'fa-info-circle';
            const alertClass = {
                success: 'alert-success',
                error: 'alert-danger',
                warning: 'alert-warning',
                info: 'alert-info'
            }[type];

            container.innerHTML = `
                <div class="alert ${alertClass} p-3 rounded alert-dismissible fade show" role="alert">
                    <i class="fas ${icon} me-2"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            
            // Ocultar automáticamente después de 7 segundos
            setTimeout(() => {
                const alertElement = container.querySelector('.alert');
                if (alertElement) {
                    // Manual removal if Bootstrap JS object is not fully initialized/available
                    alertElement.remove();
                }
            }, 7000);
        }

        // ===========================================
        // 6. CÓDIGO DE INICIALIZACIÓN DE DATOS DE RANKING (Simulado)
        // ===========================================

        // Puntos totales base del usuario actual (se actualizará al guardar)
        let userTotalPoints = 145; 

        /**
         * Actualiza los puntos totales del usuario actual en el ranking público.
         * Para esta simulación, solo incrementamos una pequeña cantidad en el total
         * para mostrar que la interacción con el ranking funciona.
         * @param {number} newPoints - Puntos obtenidos en la jornada actual.
         */
        async function updateRankingScore(newPoints) {
            if (!db || !userId) return;
            
            // Simulación: sumamos los puntos de la jornada al total
            userTotalPoints += newPoints;

            const rankingCollectionRef = collection(db, 'artifacts', appId, 'public', 'data', 'ranking');
            const userDocRef = doc(rankingCollectionRef, userId);

            try {
                await setDoc(userDocRef, { 
                    userId: userId, 
                    nombre: `Jugador ${userId.substring(0, 5)} (Tú)`, 
                    puntos_totales: userTotalPoints 
                }, { merge: true });
                console.log(`Puntos del usuario (${userId.substring(0, 5)}) actualizados a ${userTotalPoints}`);
            } catch (e) {
                console.error("Error al actualizar ranking del usuario:", e);
            }
        }

        async function seedRanking() {
            if (!db || !userId) return; // Asegurar que la DB y el ID de usuario estén listos

            const rankingCollectionRef = collection(db, 'artifacts', appId, 'public', 'data', 'ranking');
            
            const seedData = [
                { userId: 'sim_1', nombre: 'Laura C. (Finca El Roble)', puntos_totales: 138 },
                { userId: 'sim_2', nombre: 'Javier M. (Seguridad)', puntos_totales: 130 },
                { userId: 'sim_3', nombre: 'Ana P. (Logística)', puntos_totales: 112 },
                { userId: 'sim_4', nombre: 'Carlos R. (Mecánica)', puntos_totales: 105 },
                { userId: 'sim_5', nombre: 'María Z. (Comercial)', puntos_totales: 98 },
            ];

            for (const data of seedData) {
                const docRef = doc(rankingCollectionRef, data.userId);
                try {
                    // Usar setDoc con merge: true para evitar sobrescribir si ya existe
                    await setDoc(docRef, data, { merge: true }); 
                } catch (e) {
                    console.error("Error al sembrar datos de ranking:", e);
                }
            }
            
            // Inicializar/Actualizar el usuario actual
            await updateRankingScore(0); // Poner los puntos base

        }
    </script>


    </body>
</html>
<%- include('../layouts/footer.ejs') %>