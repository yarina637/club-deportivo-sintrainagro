<%- include('../layouts/header.ejs') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg p-4">
            <div class="card-body"> 
                <form id="calcForm">
        
                    <div class="mb-3">
                        <label for="peso" class="form-label fw-bold">Peso Corporal (kg)</label>
                        <input type="number" class="form-control" id="peso" required min="10">
                    </div>

                    <div class="mb-3">
                        <label for="actividad" class="form-label fw-bold">Tipo de Actividad (METs)</label>
                        <select class="form-select" id="actividad" required>
                            <option value="" disabled selected>Selecciona una actividad</option>
                            <option value="3.5">Caminar Rápido (3.5 METs)</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="tiempo" class="form-label fw-bold">Tiempo de Ejercicio (minutos)</label>
                        <input type="number" class="form-control" id="tiempo" required min="1">
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100">
                        Calcular Calorías
                    </button>
                </form> 
                
                <div id="resultado" class="alert alert-info mt-4 text-center d-none">
                    </div>
            </div> </div> </div> </div> <script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('calcForm');
        const resultadoDiv = document.getElementById('resultado');

        // 1. Asegúrate de que el ID 'calcForm' sea correcto en tu HTML
        if (!form) {
            console.error("No se encontró el formulario con ID 'calcForm'.");
            return; // Detiene la ejecución si no encuentra el formulario
        }

        form.addEventListener('submit', function(e) {
            // 2. CRÍTICO: Previene el envío del formulario que recarga la página
            e.preventDefault(); 

            // 3. Obtención y Conversión de valores
            const peso = parseFloat(document.getElementById('peso').value);
            const met = parseFloat(document.getElementById('actividad').value);
            const tiempo = parseFloat(document.getElementById('tiempo').value);

            // 4. Validación: Revisa si la conversión fue exitosa y si los números son válidos
            if (isNaN(peso) || isNaN(met) || isNaN(tiempo) || peso <= 0 || met <= 0 || tiempo <= 0) {
                resultadoDiv.classList.remove('d-none', 'alert-info');
                resultadoDiv.classList.add('alert-danger');
                resultadoDiv.innerHTML = '<p class="mb-0 fw-bold">¡Por favor, ingresa todos los valores válidos!</p>';
                return; // Detiene el cálculo si hay error
            }

            // 5. CÁLCULO
            // Fórmula: Kcal/min = (METs * peso_kg * 3.5) / 200
            const caloriasPorMinuto = (met * peso * 3.5) / 200;
            const caloriasTotales = caloriasPorMinuto * tiempo;

            // 6. MOSTRAR RESULTADO
            resultadoDiv.classList.remove('d-none', 'alert-danger');
            resultadoDiv.classList.add('alert-info');
            
            resultadoDiv.innerHTML = `
                <h4 class="fw-bold mb-0">Estimación de Calorías:</h4>
                <p class="display-6 text-success fw-bold">${Math.round(caloriasTotales)} Kcal</p>
                <p class="small text-muted mb-0">El cálculo es una estimación. Consulta a un profesional.</p>
                `;
        });
    });
</script>

<%- include('../layouts/footer.ejs') %>