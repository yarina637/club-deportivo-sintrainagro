<%- include('../layouts/header.ejs') %>
<%# views/juegos/secuencia.ejs %>

<style>
    /* Estilos específicos para la cuadrícula del juego de secuencia */
    .game-board {
        display: grid;
        grid-template-columns: repeat(2, 1fr); /* 2 columnas */
        gap: 15px;
        width: 300px;
        height: 300px;
        margin: 20px auto;
        border: 5px solid #bdc3c7;
        padding: 15px;
        border-radius: 10px;
    }
    .cell {
        width: 100%;
        height: 100%;
        border-radius: 5px;
        cursor: pointer;
        opacity: 0.8;
        transition: opacity 0.1s, transform 0.1s;
        user-select: none;
    }
    /* CLASE CLAVE: Efecto de brillo para la secuencia del PC */
    .active-flash {
        opacity: 1.0;
        transform: scale(1.05);
        box-shadow: 0 0 20px rgba(255, 255, 255, 0.8), 0 0 10px rgba(0, 0, 0, 0.5);
        filter: brightness(1.2); /* Aumenta el brillo */
    }
</style>

<div class="container py-5">
    <div id="game-section" style="max-width: 500px; margin: 0 auto; text-align: center;">
<h6 class="display-6 fw-bold text-success mb-2">🧠 Cerebro Activo: Secuencia</h6>
        <p class="lead">Memoriza la secuencia de activación de colores.</p>

        <div id="score-board" class="mb-3 fs-4 fw-bold">Nivel: <span id="level">1</span></div>
        
        <button id="start-button" class="btn btn-primary btn-lg mb-3">Comenzar</button>

        <div id="game-board" class="game-board">
            <div class="cell" data-id="0" style="background-color: #2ecc71;"></div> <div class="cell" data-id="1" style="background-color: #3498db;"></div> <div class="cell" data-id="2" style="background-color: #f1c40f;"></div> <div class="cell" data-id="3" style="background-color: #e74c3c;"></div> </div>

        <p id="message" class="mt-3 lead text-muted">Presiona "Comenzar" para iniciar el desafío.</p>
    </div>
</div>

<script>
    // **********************************************
    // LÓGICA DEL JUEGO DE SECUENCIA (TODA LA LÓGICA DE JUEGO.JS)
    // **********************************************

    // --- Variables Globales ---
    const cells = document.querySelectorAll('.cell');
    const startButton = document.getElementById('start-button');
    const levelElement = document.getElementById('level');
    const messageElement = document.getElementById('message');

    let sequencePC = [];
    let sequencePlayer = [];
    let level = 1;
    let canClick = false; 
    let isPlaying = false; 

    // --- Funciones del Juego ---

    function nextLevel() {
        canClick = false;
        sequencePlayer = [];
        levelElement.textContent = level;
        messageElement.textContent = '¡Observa con atención!';
        
        const randomCellId = Math.floor(Math.random() * cells.length);
        sequencePC.push(randomCellId);
        
        setTimeout(playSequence, 1000); 
    }

    function playSequence() {
        let i = 0;
        const interval = setInterval(() => {
            const idToActivate = sequencePC[i];
            
            const cell = document.querySelector(`[data-id="${idToActivate}"]`);
            activateCell(cell);
            
            i++;
            if (i >= sequencePC.length) {
                clearInterval(interval);
                
                canClick = true;
                messageElement.textContent = '¡Tu turno! Repite la secuencia.';
            }
        }, 700); 
    }

    function activateCell(cell) {
        cell.classList.add('active-flash');
        setTimeout(() => {
            cell.classList.remove('active-flash');
        }, 350); 
    }

    function checkPlayerInput(clickedCellId) {
        sequencePlayer.push(parseInt(clickedCellId));

        const index = sequencePlayer.length - 1;

        if (sequencePlayer[index] !== sequencePC[index]) {
            gameOver();
            return;
        }

        if (sequencePlayer.length === sequencePC.length) {
            level++;
            messageElement.textContent = '✅ ¡Correcto! Preparando Nivel ' + level;
            setTimeout(nextLevel, 1500); 
        }
    }

    function gameOver() {
        isPlaying = false;
        canClick = false;
        messageElement.textContent = `❌ ¡Fin del juego! Llegaste al Nivel ${level}.`;
        startButton.textContent = 'Volver a Jugar';
        startButton.disabled = false;
        
        // Resetear el estado para el próximo juego
        sequencePC = [];
        level = 1;
    }

    function handleCellClick(event) {
        // Solo permite clics en las celdas, no en el game-board o container
        if (!canClick || !event.target.classList.contains('cell')) return; 
        
        const clickedCellId = event.target.dataset.id;
        
        activateCell(event.target);
        
        checkPlayerInput(clickedCellId);
    }

    function startGame() {
        if (isPlaying) return; 

        isPlaying = true;
        startButton.disabled = true;
        startButton.textContent = 'En curso...';
        
        nextLevel();
    }

    // --- Configuración de Eventos Iniciales (Se ejecuta al cargar el script) ---

    // Añadir listener al contenedor del juego para delegar los clics de las celdas
    document.getElementById('game-board').addEventListener('click', handleCellClick);
    
    // Listener para el botón de inicio
    startButton.addEventListener('click', startGame);

</script>

<%- include('../layouts/footer.ejs') %>