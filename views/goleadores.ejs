<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Goleadores | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        .font-oswald { font-family: 'Oswald', sans-serif; }
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-slate-900 text-white min-h-screen" x-data="{ categoria: 'masculino' }">

<header style="background-color: #064e3b;" class="text-white shadow-2xl border-b-4 border-yellow-500 sticky top-0 z-50">
    <div class="container mx-auto px-6 py-4">
        <div class="flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="bg-white p-2 rounded-2xl shadow-2xl transform -rotate-2">
                    <img src="/img/logoclub.png" alt="Logo" class="h-20 w-auto">
                </div>
                <div>
                    <h1 class="font-oswald text-3xl font-black uppercase italic leading-none tracking-tighter">
                        Club <span class="text-yellow-400">Deportivo</span>
                    </h1>
                </div>
            </div>
            <nav class="flex gap-2">
                <a href="/publico" class="bg-yellow-500 text-green-900 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">Inicio</a>
                <button onclick="window.history.back()" class="bg-[#0a6d52] text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase border border-[#10a37b]">Volver</button>
            </nav>
        </div>
    </div>
</header>

<main class="container mx-auto px-4 py-10 max-w-5xl">
    
    <div class="flex justify-center mb-12">
        <div class="inline-flex bg-white/5 p-1 rounded-2xl border border-white/10 backdrop-blur-md">
            <button @click="categoria = 'masculino'" 
                :class="categoria === 'masculino' ? 'bg-yellow-500 text-slate-900' : 'text-slate-400'"
                class="px-8 py-3 rounded-xl font-black uppercase text-xs transition-all duration-300">
                ⚽ Masculino
            </button>
            <button @click="categoria = 'femenino'" 
                :class="categoria === 'femenino' ? 'bg-pink-600 text-white' : 'text-slate-400'"
                class="px-8 py-3 rounded-xl font-black uppercase text-xs transition-all duration-300">
                ♀️ Femenino
            </button>
        </div>
    </div>

    <% if (lista.length > 0) { %>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20 items-end">
            <% 
                // Filtramos usando tus campos reales. 
                // NOTA: Asegúrate de que en tu BD la columna se llame 'categoria'
                const topMasculino = lista.filter(j => j.categoria === 'Masculino').slice(0, 3);
                const topFemenino = lista.filter(j => j.categoria === 'Femenino').slice(0, 3);
            %>

            <template x-if="categoria === 'masculino'">
                <div class="contents">
                    <% topMasculino.forEach((jugador, index) => { %>
                        <div class="order-<%= index === 0 ? '1 md:order-2' : (index === 1 ? '2 md:order-1' : '3') %>">
                            <div class="relative group">
                                <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10 bg-yellow-500 text-slate-900 font-black px-4 py-1 rounded-full text-xs">#<%= index + 1 %></div>
                                <div class="relative overflow-hidden rounded-[2.5rem] border-4 border-yellow-500 bg-slate-800 shadow-2xl transition-transform group-hover:-translate-y-2">
                                    <img src="/uploads/<%= jugador.foto_jugador || 'default-player.png' %>" class="w-full h-64 object-cover">
                                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
                                    <div class="absolute bottom-4 left-0 right-0 text-center">
                                        <h3 class="font-oswald text-xl text-white font-bold uppercase"><%= jugador.nombre_jugador %></h3>
                                        <p class="text-yellow-400 font-black text-[10px] uppercase"><%= jugador.finca %></p>
                                    </div>
                                </div>
                                <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 bg-white text-slate-900 rounded-full flex items-center justify-center shadow-xl font-oswald text-xl font-black">
                                    <%= jugador.goles %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </template>

            <template x-if="categoria === 'femenino'">
                <div class="contents">
                    <% topFemenino.forEach((jugador, index) => { %>
                        <div class="order-<%= index === 0 ? '1 md:order-2' : (index === 1 ? '2 md:order-1' : '3') %>">
                            <div class="relative group">
                                <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10 bg-pink-500 text-white font-black px-4 py-1 rounded-full text-xs">#<%= index + 1 %></div>
                                <div class="relative overflow-hidden rounded-[2.5rem] border-4 border-pink-500 bg-slate-800 shadow-2xl transition-transform group-hover:-translate-y-2">
                                    <img src="/uploads/<%= jugador.foto_jugador || 'default-player.png' %>" class="w-full h-64 object-cover">
                                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
                                    <div class="absolute bottom-4 left-0 right-0 text-center">
                                        <h3 class="font-oswald text-xl text-white font-bold uppercase"><%= jugador.nombre_jugador %></h3>
                                        <p class="text-pink-300 font-black text-[10px] uppercase"><%= jugador.finca %></p>
                                    </div>
                                </div>
                                <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 bg-white text-slate-900 rounded-full flex items-center justify-center shadow-xl font-oswald text-xl font-black">
                                    <%= jugador.goles %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </template>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[2rem] overflow-hidden backdrop-blur-sm">
            <table class="w-full text-left">
                <thead :class="categoria === 'masculino' ? 'bg-yellow-500 text-slate-900' : 'bg-pink-600 text-white'" class="font-oswald uppercase text-xs">
                    <tr>
                        <th class="p-5">Ranking</th>
                        <th class="p-5">Goleador</th>
                        <th class="p-5">Finca</th>
                        <th class="p-5 text-center">Goles</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% lista.forEach((jugador, index) => { %>
                        <tr x-show="categoria === '<%= jugador.categoria ? jugador.categoria.toLowerCase() : 'masculino' %>'" class="hover:bg-white/5 transition-colors">
                            <td class="p-5 font-black text-slate-500">#<%= index + 1 %></td>
                            <td class="p-5 font-bold uppercase text-sm text-white"><%= jugador.nombre_jugador %></td>
                            <td class="p-5 text-xs text-slate-400 uppercase"><%= jugador.finca %></td>
                            <td class="p-5 text-center">
                                <span class="font-oswald text-2xl font-black text-yellow-400"><%= jugador.goles %></span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    <% } else { %>
        <div class="text-center py-20 opacity-30">
            <p class="uppercase font-bold tracking-[0.5em]">No hay goleadores registrados</p>
        </div>
    <% } %>
</main>

<footer class="bg-[#052e21] text-white pt-16 pb-8 mt-20 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
            
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 mb-2 tracking-widest text-lg font-bold">Club Deportivo</h4>
                <p class="text-green-100/40 text-[11px] leading-relaxed">
                    Portal oficial de noticias y resultados.<br>
                    Sintrainagro 2026.
                </p>
            </div>

            <div class="flex flex-col items-center justify-center">
                <div class="bg-white/5 p-6 rounded-3xl border border-white/10 backdrop-blur-sm flex justify-center gap-8 w-full">
                    <a href="https://www.comfama.com" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfama.png" alt="Comfama" class="h-10 w-auto">
                    </a>
                    <a href="https://www.comfenalcoantioquia.com.co" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfenalco.png" alt="Comfenalco" class="h-10 w-auto">
                    </a>
                </div>
                </div>

            <div class="text-center md:text-right">
                <p class="text-2xl font-black uppercase tracking-widest text-white italic leading-none">Sintrainagro</p>
                <div class="h-1 w-12 bg-yellow-500 ml-auto my-3 hidden md:block"></div>
                <p class="text-green-500 text-[10px] uppercase font-bold tracking-wider">
                    © 2026 Urabá: <span class="text-white">Tierra de campeones</span>
                </p>
            </div>

        </div>

        <div class="mt-12 pt-8 border-t border-white/5 text-center">
            <p class="text-[9px] text-white/20 uppercase tracking-[0.5em]">Desarrollo Técnico - Comité Deportivo</p>
        </div>
    </div>
</footer>
</body>
</html>