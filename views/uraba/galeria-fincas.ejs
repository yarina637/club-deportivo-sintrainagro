<%- include('../layouts/header') %>

<main class="container py-4">
    <h1 class="text-center mb-5 fw-bold text-success">Galería de Equipos Participantes del Torneo</h1>
    
    <div class="row">
        
        <div class="col-sm-6 col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <img src="/images/Deportivo/galeria_fcas/dallas_foto1.jpeg" class="card-img-top" alt="Finca Dallas" style="height: 200px; object-fit: cover;">
                <div class="card-body text-center">
                    <h5 class="card-title fw-bold">Finca Dallas</h5>
                    <p class="card-text small text-muted">Subcampeones de la temporada.</p>
                    <button class="btn btn-primary mt-2 ver-galeria" data-finca-id="dallas">
                        Ver Galería Completa
                    </button>
                </div>
            </div>
        </div>
        
        <div class="col-sm-6 col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <img src="/images/Deportivo/galeria_fcas/cafetal_foto1.jpeg" class="card-img-top" alt="Finca El Cafetal" style="height: 200px; object-fit: cover;">
                <div class="card-body text-center">
                    <h5 class="card-title fw-bold">Finca El Cafetal</h5>
                    <p class="card-text small text-muted">Semifinalistas del torneo.</p>
                    <button class="btn btn-primary mt-2 ver-galeria" data-finca-id="cafetal">
                        Ver Galería Completa
                    </button>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <img src="/images/Deportivo/galeria_fcas/matogroso_foto1.jpeg" class="card-img-top" alt="Finca Matogroso" style="height: 200px; object-fit: cover;">
                <div class="card-body text-center">
                    <h5 class="card-title fw-bold">Finca Matrogroso</h5>
                    <p class="card-text small text-muted">Semifinalistas del torneo.</p>
                    <button class="btn btn-primary mt-2 ver-galeria" data-finca-id="matogroso">
                        Ver Galería Completa
                    </button>
                </div>
            </div>
        </div>
        
    </div>
    
    <div class="text-center mt-5 mb-3">
        <a href="/uraba/femenino" class="btn btn-lg btn-secondary">
            <i class="fas fa-futbol me-2"></i> Volver a la Página Principal
        </a>
    </div>

</main>

<div class="modal fade" id="modalGaleriaFotos" tabindex="-1" aria-labelledby="modalGaleriaFotosLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalGaleriaFotosLabel">Cargando Galería...</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                
                <div id="carrusel-fotos-equipo" class="carousel slide">
                    
                    <div class="carousel-inner">
                        </div>
                    
                    <button class="carousel-control-prev" type="button" data-bs-target="#carrusel-fotos-equipo" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Anterior</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carrusel-fotos-equipo" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Siguiente</span>
                    </button>
                </div>
                
            </div>
        </div>
    </div>
</div>
<script>
const datosGaleria = {
    "dallas": {
        nombre: "Finca Dallas",
        fotos: [
            "/images/Deportivo/galeria_fcas/dallas_foto1.jpeg",
            "/images/Deportivo/galeria_fcas/dallas_foto2.jpeg",
        ]
    },
    "cafetal": {
        nombre: "Finca El Cafetal",
        fotos: [
            "/images/Deportivo/galeria_fcas/cafetal_foto1.jpeg",
            "/images/Deportivo/galeria_fcas/cafetal_foto2.jpeg",
        ]
    },
    "matogroso": {
        nombre: "Finca Matogroso",
        fotos: [
            "/images/Deportivo/galeria_fcas/matogroso_foto1.jpeg",
            "/images/Deportivo/galeria_fcas/matogroso_foto2.jpeg", 
        ]
    }
};

document.addEventListener('DOMContentLoaded', function() {
    const modalElement = document.getElementById('modalGaleriaFotos');
    const modal = typeof bootstrap !== 'undefined' ? new bootstrap.Modal(modalElement) : null; 
    
    const modalTitle = document.getElementById('modalGaleriaFotosLabel');
    const carruselElement = document.getElementById('carrusel-fotos-equipo');
    const carruselInner = carruselElement.querySelector('.carousel-inner');
    
    const botonesGaleria = document.querySelectorAll('.ver-galeria');

    botonesGaleria.forEach(boton => {
        boton.addEventListener('click', function() {
            const fincaId = this.getAttribute('data-finca-id');
            abrirModalFotos(fincaId);
        });
    });

    function abrirModalFotos(fincaId) {
        const fincaData = datosGaleria[fincaId];
        
        if (!fincaData) {
            console.error(`Datos no encontrados para la finca: ${fincaId}`);
            return;
        }

        carruselInner.innerHTML = '';
        modalTitle.textContent = `Galería de Fotos: ${fincaData.nombre}`;
        
        fincaData.fotos.forEach((fotoRuta, index) => {
            const itemDiv = document.createElement('div');
            itemDiv.classList.add('carousel-item');
            
            if (index === 0) {
                itemDiv.classList.add('active');
            }
            
            itemDiv.innerHTML = `
                <img src="${fotoRuta}" class="d-block w-100" style="max-height: 80vh; object-fit: contain;" alt="Foto del equipo ${fincaData.nombre} #${index + 1}">
            `;
            
            carruselInner.appendChild(itemDiv);
        });

        if (modal) {
            modal.show();
        }
        
    }
});


</script>

<%- include('../layouts/footer') %>