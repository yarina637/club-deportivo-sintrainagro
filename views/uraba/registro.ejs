<%- include('../layouts/header') %> 
<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            
            <div class="card shadow-lg p-4">
                <div class="card-body">
                    <h2 class="card-title text-center mb-4 fw-bold text-primary">Portal del Afiliado</h2>
                    <p class="text-center text-muted mb-4">Ingresa tus datos para verificar tu registro en el programa de bonos estudiantiles.</p>
                    
                    <form action="/uraba/registro" method="POST">                        
                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= error %>
                            </div>
                        <% } %>

                        <div class="mb-3">
                            <label for="identificacion" class="form-label fw-semibold">Número de Identificación</label>
                            <input type="text" class="form-control" id="identificacion" name="identificacion" required>
                            <div class="form-text">Cédula o documento de identidad del afiliado principal.</div>
                        </div>

                        <div class="mb-3">
                            <label for="nombre" class="form-label fw-semibold">Nombre Completo</label>
                            <input type="text" class="form-control" id="nombre" name="nombre" required>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">Correo Electrónico</label>
                            <input type="email" class="form-control" id="email" name="email" required>
                        </div>
                        
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">
                                <i class="fas fa-check-circle me-2"></i> Verificar y Acceder
                            </button>
                            <a href="/" class="btn btn-outline-secondary mt-2">Volver al Inicio</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../layouts/footer') %>