<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calendario y Resultados | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
    <style>
        .font-oswald { font-family: 'Oswald', sans-serif; }
    </style>
</head>
<body class="bg-[#e2e8f0] text-slate-900 font-sans">

    <header style="background-color: #064e3b;" class="text-white shadow-2xl border-b-4 border-yellow-500 sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-6">
                    <div class="bg-white p-2 rounded-2xl shadow-2xl transform -rotate-2 hover:rotate-0 transition-all duration-300">
                        <img src="/img/logoclub.png" alt="Logo" class="h-16 w-auto object-contain">
                    </div>
                    <div>
                        <h1 class="font-oswald text-2xl font-black uppercase italic leading-none tracking-tighter">
                            Calendario <span class="text-yellow-400">Oficial</span>
                        </h1>
                        <p class="text-[8px] uppercase tracking-[0.3em] font-bold text-green-200 mt-1">Sintrainagro 2026</p>
                    </div>
                </div>
                <a href="/publico" class="bg-yellow-500 hover:bg-yellow-400 text-green-900 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-lg hover:scale-105">
                    Volver al Inicio
                </a>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-12">
        <div class="max-w-5xl mx-auto">
            
            <div class="flex justify-between items-end mb-8 border-b-4 border-[#064e3b] pb-2">
                <h2 class="font-oswald text-3xl uppercase font-black italic text-[#064e3b]">Fixture del Torneo</h2>
                <span class="text-[10px] font-black uppercase text-slate-400 tracking-widest pb-1">Temporada 2026</span>
            </div>

            <div class="grid gap-6">
                <% if (partidos && partidos.length > 0) { %>
                    <% partidos.forEach(partido => { %>
                        <div class="group bg-white rounded-3xl shadow-md overflow-hidden border border-slate-200 flex flex-col md:flex-row transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                            
                            <div class="bg-slate-50 p-6 flex flex-col items-center justify-center border-b md:border-b-0 md:border-r border-slate-100 min-w-[140px]">
                                <span class="text-[#064e3b] font-black text-2xl uppercase italic font-oswald leading-none">
                                    <%= new Date(partido.fecha_hora).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' }) %>
                                </span>
                                <span class="text-slate-400 font-bold text-[10px] uppercase mt-1 tracking-widest">
                                    <%= new Date(partido.fecha_hora).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) %>
                                </span>
                            </div>

                            <div class="flex-grow p-6 flex items-center justify-between gap-4 bg-white">
                                <div class="text-center flex-1">
                                    <h4 class="font-oswald font-bold text-base md:text-xl text-slate-800 uppercase leading-tight tracking-tight">
                                        <%= partido.equipo_local %>
                                    </h4>
                                </div>

                                <div class="flex flex-col items-center min-w-[80px] md:min-w-[120px]">
                                    <% if (partido.goles_local !== null && partido.goles_visitante !== null) { %>
                                        <div class="flex items-center gap-2">
                                            <span class="bg-slate-900 text-yellow-400 font-black text-2xl md:text-3xl px-3 py-1 rounded-xl shadow-inner font-oswald">
                                                <%= partido.goles_local %>
                                            </span>
                                            <span class="text-slate-300 font-black text-xl">-</span>
                                            <span class="bg-slate-900 text-yellow-400 font-black text-2xl md:text-3xl px-3 py-1 rounded-xl shadow-inner font-oswald">
                                                <%= partido.goles_visitante %>
                                            </span>
                                        </div>
                                        <span class="text-[8px] text-green-600 font-black uppercase mt-2 tracking-tighter bg-green-50 px-2 py-0.5 rounded-full">Finalizado</span>
                                    <% } else { %>
                                        <span class="bg-yellow-500 text-green-900 px-4 py-1 rounded-full text-[10px] font-black italic shadow-sm uppercase transform group-hover:scale-110 transition-transform">
                                            VS
                                        </span>
                                        <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mt-2">Programado</span>
                                    <% } %>
                                </div>

                                <div class="text-center flex-1">
                                    <h4 class="font-oswald font-bold text-base md:text-xl text-slate-800 uppercase leading-tight tracking-tight">
                                        <%= partido.equipo_visitante %>
                                    </h4>
                                </div>
                            </div>

                            <div class="bg-[#064e3b] p-6 flex flex-col items-center justify-center text-white min-w-[180px] border-t md:border-t-0 md:border-l border-yellow-500/20 transition-all duration-300 group-hover:shadow-[inset_0_0_20px_rgba(250,204,21,0.2)]">
                                <span class="text-[9px] uppercase font-black text-yellow-400 mb-1 tracking-[0.2em]">Sede del Encuentro</span>
                                <span class="text-xs font-bold text-center uppercase leading-tight italic text-green-50">
                                    <%= partido.lugar %>
                                </span>
                                <div class="mt-3 flex items-center gap-1">
                                    <div class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></div>
                                    <span class="text-[8px] font-black uppercase tracking-widest text-yellow-500/80"><%= partido.categoria %></span>
                                </div>
                            </div>

                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-20 bg-white rounded-[3rem] border-4 border-dashed border-slate-200">
                        <span class="text-5xl block mb-4 opacity-20">⚽</span>
                        <p class="font-oswald text-slate-400 text-xl uppercase font-bold tracking-widest">No hay partidos registrados aún</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

<footer class="bg-[#052e21] text-white pt-16 pb-8 mt-20 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
            
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 mb-2 tracking-widest text-lg font-bold">Club Deportivo</h4>
                <p class="text-green-100/40 text-[11px] leading-relaxed">
                    Portal oficial de noticias y resultados.<br>
                    Sintrainagro 2026.
                </p>
            </div>

            <div class="flex flex-col items-center justify-center">
                <div class="bg-white/5 p-6 rounded-3xl border border-white/10 backdrop-blur-sm flex justify-center gap-8 w-full">
                    <a href="https://www.comfama.com" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfama.png" alt="Comfama" class="h-10 w-auto">
                    </a>
                    <a href="https://www.comfenalcoantioquia.com.co" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfenalco.png" alt="Comfenalco" class="h-10 w-auto">
                    </a>
                </div>
                </div>

            <div class="text-center md:text-right">
                <p class="text-2xl font-black uppercase tracking-widest text-white italic leading-none">Sintrainagro</p>
                <div class="h-1 w-12 bg-yellow-500 ml-auto my-3 hidden md:block"></div>
                <p class="text-green-500 text-[10px] uppercase font-bold tracking-wider">
                    © 2026 Urabá: <span class="text-white">Tierra de campeones</span>
                </p>
            </div>

        </div>

        <div class="mt-12 pt-8 border-t border-white/5 text-center">
            <p class="text-[9px] text-white/20 uppercase tracking-[0.5em]">Desarrollo Técnico - Comité Deportivo</p>
        </div>
    </div>
</footer>
</body>
</html>