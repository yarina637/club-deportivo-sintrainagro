<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= noticia.titulo %> | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50"> <header style="background-color: #064e3b;" class="text-white shadow-2xl border-b-4 border-yellow-500 sticky top-0 z-50">
    <div class="container mx-auto px-6 py-4">
        <div class="flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="bg-white p-2 rounded-2xl shadow-2xl transform -rotate-2 hover:rotate-0 transition-transform duration-300">
                    <img src="/img/logoclub.png" alt="Logo Club" class="h-28 w-auto object-contain">
                </div>
                <div class="hidden sm:block">
                    <h1 class="font-oswald text-4xl font-black uppercase italic leading-none tracking-tighter">
                        Club <span class="text-yellow-400">Deportivo</span>
                    </h1>
                    <p class="text-xs uppercase tracking-[0.4em] font-bold text-green-200 mt-2 flex items-center gap-2">
                        <span class="w-2 h-2 bg-yellow-500 rounded-full animate-ping"></span>
                        Sintrainagro 2026
                    </p>
                </div>
            </div>
            <nav class="flex items-center gap-3">
                <a href="/publico" class="flex items-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-green-900 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">
                    Inicio
                </a>
                <button onclick="window.history.back()" class="flex items-center gap-2 bg-[#0a6d52] hover:bg-[#0c8564] text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border border-[#10a37b]">
                    Volver
                </button>
            </nav>
        </div>
    </div>
</header>

<main class="max-w-4xl mx-auto min-h-screen shadow-2xl bg-white">
    <div class="w-full h-[50vh] md:h-[60vh] relative overflow-hidden">
        <img src="<%= noticia.imagen_url %>" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
        <div class="absolute bottom-10 px-6 md:px-12 w-full">
            <% 
                let claseColor = 'bg-yellow-500 text-blue-900';
                let texto = 'Crónica Oficial';
                if(noticia.categoria === 'Femenino') { claseColor = 'bg-pink-600 text-white'; texto = 'Fútbol Femenino'; }
                if(noticia.categoria === 'Masculino') { claseColor = 'bg-yellow-500 text-green-900'; texto = 'Fútbol Masculino'; }
            %>
            <span class="<%= claseColor %> px-3 py-1 rounded text-[10px] font-black uppercase mb-4 inline-block italic shadow-lg">
                <%= texto %>
            </span>
            <h1 class="text-white font-oswald text-3xl md:text-5xl uppercase italic font-bold leading-tight drop-shadow-lg">
                <%= noticia.titulo %>
            </h1>
        </div>
    </div> <article class="px-6 md:px-12 py-12 bg-white">
        <div class="prose prose-slate lg:prose-xl mx-auto">
            <p class="text-slate-700 leading-relaxed text-lg md:text-xl whitespace-pre-wrap font-light">
                <%= noticia.contenido %>
            </p>
        </div>
        
<p class="text-slate-500 font-bold text-xs uppercase tracking-widest mb-4">
    📅 
    <% if (noticia.fecha) { %>
        <%= new Date(noticia.fecha).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) %>
    <% } else { %>
        <%= new Date().toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) %>
    <% } %>
</p>

        <div class="mt-16 pt-8 border-t border-slate-100 flex flex-col items-center">
            <p class="text-slate-400 text-xs font-bold uppercase tracking-[0.3em] mb-4">Compartir noticia</p>
            <div class="flex gap-4">
                <button onclick="window.print()" class="p-4 bg-slate-50 rounded-full hover:bg-yellow-100 transition-all border border-slate-200">🖨️</button>
                <a href="https://wa.me/?text=Mira esta noticia: <%= noticia.titulo %>" target="_blank" class="flex items-center gap-2 px-6 py-3 bg-green-500 text-white rounded-full hover:bg-green-600 transition-all font-bold text-sm shadow-lg">
                    <span>📱</span> WhatsApp
                </a>
            </div>
        </div>
    </article>
</main>

<footer class="bg-[#052e21] text-white pt-16 pb-8 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 mb-2 tracking-widest text-lg font-bold">Club Deportivo</h4>
                <p class="text-green-100/40 text-[11px] leading-relaxed">
                    Portal oficial de noticias y resultados.<br>
                    Sintrainagro 2026.
                </p>
            </div>

            <div class="flex flex-col items-center justify-center">
                <div class="bg-white/5 p-6 rounded-3xl border border-white/10 backdrop-blur-sm flex justify-center gap-8 w-full">
                    <img src="/img/comfama.png" alt="Comfama" class="h-10 w-auto opacity-80 hover:opacity-100 transition-opacity">
                    <img src="/img/comfenalco.png" alt="Comfenalco" class="h-10 w-auto opacity-80 hover:opacity-100 transition-opacity">
                </div>
            </div>

            <div class="text-center md:text-right">
                <p class="text-2xl font-black uppercase tracking-widest text-white italic leading-none">Sintrainagro</p>
                <div class="h-1 w-12 bg-yellow-500 ml-auto my-3 hidden md:block"></div>
                <p class="text-green-500 text-[10px] uppercase font-bold tracking-wider">
                    © 2026 Urabá: <span class="text-white">Tierra de campeones</span>
                </p>
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-white/5 text-center">
            <p class="text-[9px] text-white/20 uppercase tracking-[0.5em]">Desarrollo Técnico - Comité Deportivo</p>
        </div>
    </div>
</footer>

</body>
</html>