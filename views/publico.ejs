<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Noticias Oficiales | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        .font-oswald { font-family: 'Oswald', sans-serif; }
        [x-cloak] { display: none !important; }
        
        @keyframes shine {
            0% { transform: translateX(-100%) skewX(-15deg); }
            100% { transform: translateX(300%) skewX(-15deg); }
        }

        .bar-shine { position: relative; overflow: hidden; }

        .bar-shine::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 150px;
            height: 100%;
            background: linear-gradient(
                to right, 
                transparent, 
                rgba(255, 255, 255, 0.2), 
                transparent
            );
            animation: shine 4s infinite;
            pointer-events: none;
            z-index: 30;
        }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-[#e2e8f0] text-slate-900 selection:bg-yellow-200 font-sans">

<header style="background-color: #064e3b;" class="text-white shadow-2xl border-b-4 border-yellow-500 sticky top-0 z-50">
    <div class="container mx-auto px-6 py-4">
        <div class="flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="bg-white p-2 rounded-2xl shadow-2xl transform -rotate-2 hover:rotate-0 transition-transform duration-300 shadow-yellow-500/20">
                    <img src="/img/logoclub.png" alt="Logo Club" class="h-24 w-auto object-contain">
                </div>
                <div class="hidden sm:block">
                    <h1 class="font-oswald text-4xl font-black uppercase italic leading-none tracking-tighter">
                        Club <span class="text-yellow-400">Deportivo</span>
                    </h1>
                    <p class="text-xs uppercase tracking-[0.4em] font-bold text-green-200 mt-2 flex items-center gap-2">
                        <span class="w-2 h-2 bg-yellow-500 rounded-full animate-ping"></span>
                        Sintrainagro 2026
                    </p>
                </div>
            </div>

            <nav class="flex items-center gap-3">
                <a href="/nosotros" class="flex items-center gap-2 bg-green-800 hover:bg-green-700 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-lg hover:scale-105 border border-green-500/30">
                    👣 Identidad
                </a>

                <a href="/publico" class="flex items-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-green-900 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-lg hover:scale-105">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    Inicio
                </a>
            </nav>
        </div>
    </div>
</header>

<div class="bar-shine bg-[#052e21] border-b-2 border-yellow-500/50 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-green-950 via-transparent to-green-950"></div>
    
    <div class="container mx-auto relative z-10">
        <div class="flex items-center">
            <div class="relative bg-gradient-to-b from-yellow-400 to-yellow-600 text-green-950 px-8 py-4 text-[12px] font-black uppercase italic tracking-tighter shadow-[10px_0_20px_rgba(0,0,0,0.4)] z-20 flex flex-col items-center justify-center border-r-4 border-yellow-700">
                <span class="flex items-center gap-2">
                    <span class="relative flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-600 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-red-700"></span>
                    </span>
                    MARCADORES
                </span>
                <span class="text-[9px] opacity-80 leading-none mt-1">JORNADA ACTUAL</span>
            </div>

            <div class="flex gap-6 overflow-x-auto py-3 px-8 no-scrollbar snap-x items-center w-full">
                <% if (partidos && partidos.length > 0) { 
                    partidos.filter(p => p.goles_local !== null).slice(0, 8).forEach(partido => { %>
                    <div class="snap-start flex-shrink-0 flex items-center bg-black/40 backdrop-blur-xl p-1 rounded-full border border-white/10 hover:border-yellow-500/50 transition-all duration-300 group">
                        <div class="flex items-center gap-3 px-4 py-1">
                            <span class="text-[11px] font-black text-white uppercase tracking-tighter group-hover:text-yellow-400 transition-colors">
                                <%= partido.equipo_local.substring(0, 15) %>
                            </span>
                            <div class="flex items-center bg-gradient-to-b from-slate-800 to-black px-3 py-1 rounded-full border border-white/5 shadow-2xl">
                                <span class="text-sm font-black text-yellow-400 font-mono w-4 text-center"><%= partido.goles_local %></span>
                                <span class="mx-2 text-white/20 text-xs">-</span>
                                <span class="text-sm font-black text-yellow-400 font-mono w-4 text-center"><%= partido.goles_visitante %></span>
                            </div>
                            <span class="text-[11px] font-black text-white uppercase tracking-tighter group-hover:text-yellow-400 transition-colors">
                                <%= partido.equipo_visitante.substring(0, 15) %>
                            </span>
                        </div>
                        <div class="bg-yellow-500/10 px-3 py-1 rounded-full ml-1 border-l border-white/5">
                            <span class="text-[8px] font-black text-yellow-500 uppercase italic">FIN</span>
                        </div>
                    </div>
                <% }); %>
                <% } else { %>
                    <div class="flex items-center gap-3 animate-pulse">
                        <span class="text-green-300/40 text-xs font-bold uppercase tracking-[0.3em]">Esperando resultados oficiales...</span>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
<main class="container mx-auto px-4 py-10" x-data="{ tabTorneo: 'masculino' }">
    <% if (noticias.length > 0) { %>
    <section class="mb-16">
        <div class="flex flex-col lg:flex-row gap-8 items-start">
            <div class="lg:w-2/3 bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100 flex flex-col group transition-all duration-500">
                <div class="h-[500px] relative overflow-hidden bg-[#064e3b]">
                    <% if (noticias[0].imagen_url) { %>
                        <img src="<%= noticias[0].imagen_url %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-90">
                    <% } %>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
                    <div class="absolute bottom-6 left-6">
                        <span class="bg-yellow-500 text-green-900 px-4 py-1.5 rounded-full text-xs font-black uppercase italic shadow-xl inline-block mb-3">🔥 Última Crónica</span>
                        <h2 class="text-3xl md:text-5xl font-oswald font-bold text-white uppercase italic leading-tight"><%= noticias[0].titulo %></h2>
                    </div>
                </div>
                <div class="p-8 md:p-12">
                    <p class="text-gray-600 text-xl md:text-2xl leading-relaxed mb-10 line-clamp-[10] italic font-light">
                        <%= noticias[0].contenido %>
                    </p>           
                    
                    <div class="mt-4">
                        <div class="flex items-center gap-2 text-[10px] font-bold text-slate-500 mb-2">
                            <span>📅</span>
                            <span>
                                <%= noticias[0].fecha ? new Date(noticias[0].fecha).toLocaleDateString('es-ES') : 'Crónica Reciente' %>
                            </span>
                        </div>
                        <a href="/noticia/<%= noticias[0].id %>" class="inline-block bg-[#064e3b] hover:bg-yellow-500 text-white hover:text-green-900 px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">
                            Leer crónica completa
                        </a>
                    </div>
                </div>
            </div> <div class="lg:w-1/3 flex flex-col gap-6 sticky top-28 self-start">
                <h3 class="font-oswald uppercase italic font-bold text-slate-400 text-sm tracking-widest ml-2">Estadísticas</h3>
                
                <a :href="'/posiciones?cat=' + tabTorneo" class="group bg-white p-5 rounded-2xl shadow-md border-l-8 transition-all duration-300 transform hover:-translate-x-2" :class="tabTorneo === 'masculino' ? 'border-green-700' : 'border-pink-600'">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <span class="text-3xl">📊</span>
                            <h4 class="font-oswald font-bold uppercase text-lg">Tabla de Posiciones</h4>
                        </div>
                        <span class="text-xl opacity-50 group-hover:opacity-100">→</span>
                    </div>
                </a>

                <div class="flex flex-col gap-3">
                    <h3 class="font-oswald uppercase italic font-bold text-slate-400 text-sm tracking-widest ml-2">Próxima Jornada</h3>
                    <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
                        <div class="max-h-[380px] overflow-y-auto no-scrollbar">
                            <% if (partidos && partidos.length > 0) { %>
                                <% partidos.slice(0, 10).forEach(partido => { %>
                                    <div class="p-4 border-b border-slate-50 hover:bg-slate-50 transition-colors">
                                        <div class="flex justify-between items-center mb-2">
                                            <span class="text-[9px] font-black <%= partido.categoria === 'Femenino' ? 'bg-pink-100 text-pink-600' : 'bg-slate-100 text-slate-500' %> px-2 py-0.5 rounded uppercase"><%= partido.lugar %></span>
                                            <span class="text-[10px] font-mono text-slate-400 uppercase font-bold tracking-widest">
                                                <%= new Date(partido.fecha_hora).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                                            </span>
                                        </div>
                                        <div class="flex items-center justify-between gap-2 text-center">
                                            <div class="flex-1 font-oswald text-[11px] font-bold uppercase text-slate-800 leading-tight"><%= partido.equipo_local %></div>
                                            <div class="font-oswald font-black text-yellow-500 text-sm italic">VS</div>
                                            <div class="flex-1 font-oswald text-[11px] font-bold uppercase text-slate-800 leading-tight"><%= partido.equipo_visitante %></div>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } %>
                        </div>
                        <a href="/calendario" class="block w-full py-4 bg-[#064e3b] text-yellow-400 text-center font-oswald text-[11px] uppercase tracking-[0.2em] font-black hover:bg-green-900 transition-all border-t border-yellow-500/30">Ver Calendario Completo</a>
                    </div>
                </div>

                <a :href="'/goleadores?cat=' + tabTorneo" class="group bg-white p-5 rounded-2xl shadow-md border-l-8 transition-all duration-300 transform hover:-translate-x-2" :class="tabTorneo === 'masculino' ? 'border-yellow-500' : 'border-pink-400'">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <span class="text-3xl">⚽</span>
                            <h4 class="font-oswald font-bold uppercase text-lg">Goleadores</h4>
                        </div>
                        <span class="text-xl opacity-50 group-hover:opacity-100">→</span>
                    </div>
                </a>

                <div class="flex flex-col gap-3">
                    <h3 class="font-oswald uppercase italic font-bold text-slate-400 text-sm tracking-widest ml-2">Explorar Galerías</h3>
                    <div class="grid grid-cols-2 gap-3">
                        <a href="/galeria/masculino" class="group relative overflow-hidden bg-sky-500 p-4 rounded-2xl shadow-lg transition-all hover:scale-[1.02] active:scale-95 border-b-4 border-sky-600">
                            <div class="relative z-10 flex flex-col items-center text-center text-white">
                                <span class="text-2xl mb-1 group-hover:rotate-12 transition-transform">🏃‍♂️</span>
                                <h4 class="font-oswald font-black uppercase text-[10px] tracking-tighter">Masculino</h4>
                            </div>
                        </a>
                        <a href="/galeria/femenino" class="group relative overflow-hidden bg-rose-400 p-4 rounded-2xl shadow-lg transition-all hover:scale-[1.02] active:scale-95 border-b-4 border-rose-600">
                            <div class="relative z-10 flex flex-col items-center text-center text-white">
                                <span class="text-2xl mb-1 group-hover:-rotate-12 transition-transform">🏃‍♀️</span>
                                <h4 class="font-oswald font-black uppercase text-[10px] tracking-tighter">Femenino</h4>
                            </div>
                        </a>
                    </div>
                </div>
            </div> </div>
    </section>

    <div class="bg-[#064e3b] p-10 rounded-[3rem] shadow-2xl mb-20 border-b-8 border-yellow-500 relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10"></div>
        <div class="relative z-10 flex flex-col lg:flex-row items-center gap-10">
            <div class="lg:w-1/3 text-center lg:text-left">
                <h4 class="font-oswald font-bold text-yellow-400 uppercase text-4xl italic leading-none">¡Únete a la Comunidad!</h4>
                <p class="text-white text-[10px] font-black uppercase tracking-[0.3em] opacity-60 mt-2">Resultados al instante vía WhatsApp</p>
            </div>
            <form action="/suscribir" method="POST" class="lg:w-2/3 w-full grid grid-cols-1 md:grid-cols-4 gap-3">
                <input type="text" name="nombre" placeholder="Nombre" required class="w-full px-4 py-4 rounded-2xl text-xs border-none outline-none focus:ring-4 focus:ring-yellow-500/50 bg-white/10 text-white placeholder:text-white/40">
                <input type="text" name="finca" placeholder="Finca" required class="w-full px-4 py-4 rounded-2xl text-xs border-none outline-none focus:ring-4 focus:ring-yellow-500/50 bg-white/10 text-white placeholder:text-white/40">
                <input type="tel" name="whatsapp" placeholder="WhatsApp" required class="w-full px-4 py-4 rounded-2xl text-xs border-none outline-none focus:ring-4 focus:ring-yellow-500/50 bg-white/10 text-white placeholder:text-white/40">
                <button type="submit" class="w-full bg-yellow-500 text-green-900 text-xs font-black uppercase py-4 rounded-2xl shadow-xl hover:bg-yellow-400 transition-all hover:scale-105 active:scale-95">
                    Unirme Ahora
                </button>
            </form>
        </div>
    </div>

<section class="mb-20">
    <div class="flex flex-col md:flex-row items-center gap-0 bg-slate-900 rounded-[3rem] overflow-hidden shadow-2xl border border-white/10">
        
        <div class="md:w-3/5 w-full h-[300px] md:h-[420px] bg-black relative group flex items-center justify-center">
            <video 
                id="videoPromocional"
                controls 
                class="max-w-full max-h-full object-contain opacity-95 group-hover:opacity-100 transition-opacity shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                <source src="/video/promocional.mp4" type="video/mp4">
                Tu navegador no soporta videos.
            </video>
            
            <div class="absolute top-4 left-4 pointer-events-none">
                <span class="bg-red-600/90 text-[8px] font-black px-3 py-1 rounded-full text-white uppercase tracking-[0.2em]">Video Oficial</span>
            </div>
        </div>

        <div class="md:w-2/5 p-10 md:p-12 flex flex-col justify-center text-center md:text-left">
            <h4 class="text-yellow-500 font-black uppercase text-[10px] tracking-[0.4em] mb-2">Especial 2026</h4>
            <h3 class="font-oswald text-4xl font-bold text-white uppercase italic leading-none mb-4">
                Urabá: <br>
                <span class="text-yellow-400">Tierra de Campeones</span>
            </h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-6">
                Mira el video completo para ver cada jugada y la pasión en el campo. ¡Sintrainagro en acción!
            </p>
            <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                <span class="bg-white/5 border border-white/10 text-white text-[9px] font-bold px-3 py-1.5 rounded-full uppercase italic">Pantalla Completa</span>
                <span class="bg-green-500/20 text-green-400 text-[9px] font-bold px-3 py-1.5 rounded-full uppercase">Crónica Visual</span>
            </div>
        </div>

    </div>
</section>

    <div class="mt-12 mb-8 flex justify-between items-end border-b-4 border-green-900 pb-2">
        <h3 class="font-oswald text-3xl uppercase italic font-black text-green-900 tracking-tighter">Más Crónicas</h3>
        <span class="text-[10px] font-black uppercase text-slate-400 tracking-[0.3em] pb-1">Archivo Deportivo</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <% noticias.slice(1).forEach((noticia) => { 
            let colorBadge = 'bg-yellow-500 text-green-900'; 
            let textoBadge = '♂️ Masculino';
            if(noticia.categoria === 'Femenino') {
                colorBadge = 'bg-pink-600 text-white';
                textoBadge = '♀️ Femenino';
            } else if(noticia.categoria === 'General') {
                colorBadge = 'bg-blue-600 text-white';
                textoBadge = '📰 General';
            }
        %>
            <div class="group bg-white rounded-[2rem] shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-200 overflow-hidden flex flex-col h-full">
                <div class="h-56 overflow-hidden relative">
                    <% if (noticia.imagen_url) { %>
                        <img src="<%= noticia.imagen_url %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                    <% } %>
                    <div class="absolute top-4 right-4 <%= colorBadge %> px-3 py-1 rounded-lg text-[10px] font-black uppercase italic shadow-lg transform group-hover:rotate-3 transition-transform">
                        <%= textoBadge %>
                    </div>
                </div>
                <div class="p-8 flex flex-col flex-grow">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="w-2 h-2 bg-green-600 rounded-full"></span>
                        <span class="text-[10px] font-mono text-slate-400 uppercase font-bold tracking-widest">
                            <%= new Date(noticia.fecha).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                        </span>
                    </div>
                    <h3 class="font-oswald text-2xl font-bold text-slate-800 uppercase leading-tight mt-2 mb-4 line-clamp-2"><%= noticia.titulo %></h3>
                    <p class="text-slate-500 text-sm leading-relaxed line-clamp-3 mb-8"><%= noticia.contenido %></p>
                    <div class="mt-auto">
                        <a href="/noticia/<%= noticia.id %>" class="inline-flex items-center justify-center w-full bg-slate-100 group-hover:bg-yellow-500 text-slate-500 group-hover:text-green-900 py-3 rounded-xl font-black uppercase text-[10px] tracking-widest transition-all duration-300">
                            Leer más 
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                        </a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    <% } %>
</main>

<footer class="bg-[#052e21] text-white pt-12 pb-8 mt-20 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
            
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 tracking-widest text-base font-bold">Club Deportivo</h4>
                <p class="text-green-100/40 text-[10px] leading-tight mb-2">
                    Portal oficial Sintrainagro 2026.
                </p>
                <a href="/nosotros" class="text-yellow-500 hover:text-yellow-400 font-oswald uppercase italic tracking-widest text-[11px] transition-colors inline-block">
                    Nuestra Historia →
                </a>
            </div>

            <div class="flex flex-col items-center gap-4">
                <div class="bg-white/10 px-8 py-4 rounded-3xl border border-white/20 backdrop-blur-md flex justify-center gap-10 w-full max-w-xs">
                    <a href="https://www.comfama.com" target="_blank" class="transition-transform hover:scale-110 active:scale-95">
                        <img src="/img/comfama.png" alt="Comfama" class="h-10 w-auto object-contain">
                    </a>
                    <a href="https://www.comfenalcoantioquia.com.co" target="_blank" class="transition-transform hover:scale-110 active:scale-95">
                        <img src="/img/comfenalco.png" alt="Comfenalco" class="h-10 w-auto object-contain">
                    </a>
                </div>
                
                <div class="text-center">
                    <p class="text-[8px] font-black uppercase tracking-[0.3em] text-green-400 mb-2">Visitas al Portal</p>
                    <div class="flex justify-center gap-1">
                        <% 
                            let totalVisitas = (typeof visitas !== 'undefined') ? visitas : 0;
                            let digitos = totalVisitas.toString().padStart(6, '0').split(''); 
                            digitos.forEach(digito => { 
                        %>
                            <span class="bg-gradient-to-b from-slate-800 to-black text-yellow-400 px-2 py-1.5 rounded-md shadow-lg font-mono text-lg font-black border border-white/10">
                                <%= digito %>
                            </span>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="text-center md:text-right flex flex-col items-center md:items-end gap-2">
                <p class="text-3xl font-black uppercase tracking-tighter text-white italic leading-none hover:text-yellow-500 transition-colors cursor-default">
                    Sintrainagro
                </p>
                
                <div class="h-1.5 w-16 bg-yellow-500 my-1 hidden md:block rounded-full"></div>
                
                <p class="text-green-400 text-[11px] font-black uppercase tracking-[0.2em] leading-tight">
                    © 2026 Urabá: <br class="md:hidden"> 
                    <span class="text-white bg-green-800 px-2 py-0.5 rounded ml-1">Tierra de campeones</span>
                </p>
                
                <p class="text-[9px] text-white/30 uppercase tracking-[0.4em] font-medium mt-2">
                    Comité Deportivo Central
                </p>
            </div>
        </div>
    </div>
</footer>
</body>
</html>