<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= noticia.titulo %> | Club Deportivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-50 text-slate-800">


    
<!-- CABECERA - ESTILO OFICIAL SINTRAINAGRO -->
<header style="background-color: #064e3b;" class="text-white shadow-2xl border-b-4 border-yellow-500 sticky top-0 z-50">
    <div class="container mx-auto px-6 py-4">
        <div class="flex justify-between items-center">
            
            <!-- LADO IZQUIERDO: LOGO Y TÍTULO -->
            <div class="flex items-center gap-6">
                <!-- CONTENEDOR DEL LOGO (MÁS GRANDE) -->
                <div class="bg-white p-2 rounded-2xl shadow-2xl transform -rotate-2 hover:rotate-0 transition-transform duration-300 shadow-yellow-500/20">
                    <img src="/img/logoclub.png" alt="Logo Club" class="h-28 w-auto object-contain">
                </div>
                
                <div class="hidden sm:block">
                    <h1 class="font-oswald text-4xl font-black uppercase italic leading-none tracking-tighter">
                        Club <span class="text-yellow-400">Deportivo</span>
                    </h1>
                    <p class="text-xs uppercase tracking-[0.4em] font-bold text-green-200 mt-2 flex items-center gap-2">
                        <span class="w-2 h-2 bg-yellow-500 rounded-full animate-ping"></span>
                        Sintrainagro 2026
                    </p>
                </div>
            </div>
            <!-- LADO DERECHO: BOTONES DE NAVEGACIÓN -->
<nav class="flex items-center gap-3">
    <!-- BOTÓN INICIO: Ahora es el sol del equipo -->
    <a href="/publico" class="flex items-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-green-900 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-lg hover:scale-105 active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Inicio
    </a>

    <!-- BOTÓN VOLVER: Elegante en verde claro o bordeado -->
    <button onclick="window.history.back()" class="flex items-center gap-2 bg-[#0a6d52] hover:bg-[#0c8564] text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border border-[#10a37b] shadow-lg hover:scale-105 active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver
    </button>
</nav>
            
        </div>
    </div>
</header>

    <main class="container mx-auto px-4 py-12 max-w-4xl">
        <article class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
            
            <!-- CONTENIDOR DE TEXTO SUPERIOR -->
            <div class="p-8 md:p-12">
                <span class="text-blue-600 font-bold uppercase tracking-widest text-xs">Crónica Oficial</span>
                <h1 class="font-oswald text-4xl md:text-6xl font-bold uppercase italic leading-tight mt-2 mb-6 text-slate-900">
                    <%= noticia.titulo %>
                </h1>
                
                <div class="flex items-center gap-4 text-gray-500 text-sm mb-8 border-b pb-6">
                    <span class="flex items-center gap-1">📅 <%= noticia.fecha_formateada %></span> 
                                       <span class="hidden md:inline">|</span>
                    <span class="font-bold text-blue-900 uppercase">Departamento de Prensa</span>
                </div>

                <!-- LA IMAGEN (Debajo del título) -->
                <% if (noticia.imagen_url) { %>
                    <div class="mb-10 rounded-2xl overflow-hidden shadow-2xl">
                        <img src="<%= noticia.imagen_url %>" alt="<%= noticia.titulo %>" class="w-full h-auto object-cover max-h-[500px]">
                    </div>
                <% } %>

                <!-- CUERPO DE LA NOTICIA -->
                <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed italic text-xl">
                    <% 
                        // Esto separa el texto por párrafos si el usuario usó saltos de línea
                        const parrafos = noticia.contenido.split('\n'); 
                        parrafos.forEach(p => { 
                    %>
                        <p class="mb-6"><%= p %></p>
                    <% }) %>
                </div>
            </div>

            <!-- PIE DE ARTÍCULO -->
            <div class="bg-slate-50 p-8 border-t border-gray-100 flex justify-center">
                <a href="/publico" class="bg-blue-600 text-white font-bold px-10 py-4 rounded-xl hover:bg-blue-700 transition-all shadow-lg uppercase tracking-widest text-sm">
                    Regresar al Inicio
                </a>
            </div>
        </article>
    </main>

<!-- FOOTER MEJORADO CON PATROCINADORES Y REDES -->
<footer class="bg-slate-900 text-white pt-16 pb-8 mt-20 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12 items-center">
            
            <!-- COLUMNA 1: REDES SOCIALES -->
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 mb-4 tracking-widest text-lg">Síguenos</h4>
                <div class="flex justify-center md:justify-start gap-5">
                    <a href="#" class="bg-blue-800 p-3 rounded-full hover:bg-blue-600 transition-transform hover:-translate-y-1 shadow-lg">
                        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href="#" class="bg-gradient-to-tr from-yellow-500 to-purple-600 p-3 rounded-full hover:scale-110 transition-transform shadow-lg">
                        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                </div>
            </div>

<!-- FOOTER: COHERENCIA TOTAL -->
<footer class="bg-[#052e21] text-white pt-16 pb-8 mt-20 border-t-8 border-yellow-500">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
            
            <div class="text-center md:text-left">
                <h4 class="font-oswald uppercase italic text-yellow-500 mb-2 tracking-widest text-lg font-bold">Club Deportivo</h4>
                <p class="text-green-100/40 text-[11px] leading-relaxed">
                    Portal oficial de noticias y resultados.<br>
                    Sintrainagro 2026.
                </p>
            </div>

            <div class="flex flex-col items-center justify-center">
                <div class="bg-white/5 p-6 rounded-3xl border border-white/10 backdrop-blur-sm flex justify-center gap-8 w-full">
                    <a href="https://www.comfama.com" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfama.png" alt="Comfama" class="h-10 w-auto">
                    </a>
                    <a href="https://www.comfenalcoantioquia.com.co" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-110">
                        <img src="/img/comfenalco.png" alt="Comfenalco" class="h-10 w-auto">
                    </a>
                </div>
                </div>

            <div class="text-center md:text-right">
                <p class="text-2xl font-black uppercase tracking-widest text-white italic leading-none">Sintrainagro</p>
                <div class="h-1 w-12 bg-yellow-500 ml-auto my-3 hidden md:block"></div>
                <p class="text-green-500 text-[10px] uppercase font-bold tracking-wider">
                    © 2026 Urabá: <span class="text-white">Tierra de campeones</span>
                </p>
            </div>

        </div>

        <div class="mt-12 pt-8 border-t border-white/5 text-center">
            <p class="text-[9px] text-white/20 uppercase tracking-[0.5em]">Desarrollo Técnico - Comité Deportivo</p>
        </div>
    </div>
</footer>
</body>
</html>